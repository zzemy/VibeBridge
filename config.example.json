{
  "version": 2,
  "listen_address": "0.0.0.0:8787",
  "web_directory": "web/dist",
  "reconnect_timeout": "90s",
  "idle_timeout": "30m",
  "disable_legacy_protocol": false,
  "workspaces": [
    {
      "id": "default",
      "label": "Current repository",
      "root": "."
    }
  ],
  "default_profile": "shell",
  "profiles": [
    {
      "id": "shell",
      "label": "PowerShell",
      "executable": "pwsh",
      "args": ["-NoLogo", "-NoExit", "-NoProfile"],
      "workspace_id": "default",
      "tool_adapter": "generic",
      "environment_allowlist": ["PATH", "PATHEXT", "SYSTEMROOT", "TEMP", "TMP", "USERPROFILE"]
    },
    {
      "id": "codex",
      "label": "Codex",
      "executable": "codex",
      "workspace_id": "default",
      "tool_adapter": "generic",
      "environment_allowlist": ["PATH", "PATHEXT", "SYSTEMROOT", "TEMP", "TMP", "USERPROFILE"]
    },
    {
      "id": "claude",
      "label": "Claude Code",
      "executable": "claude",
      "workspace_id": "default",
      "tool_adapter": "generic",
      "environment_allowlist": ["PATH", "PATHEXT", "SYSTEMROOT", "TEMP", "TMP", "USERPROFILE"]
    }
  ]
}
